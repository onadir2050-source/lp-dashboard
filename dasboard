<script>
// ─── DATA ───────────────────────────────────────────
const PAGES = {
  vente: {
    name: 'LP Management équipe vente',
    visitors: 1284, mobile: 68, desktop: 32,
    avgTime: '3:42', avgTimeSec: 222, clicks: 187,
    exits: [
      { s: 'Hero / رأس الصفحة', pct: 22 },
      { s: 'عن البرنامج', pct: 18 },
      { s: 'الفوائد والمميزات', pct: 15 },
      { s: 'الشهادات', pct: 12 },
      { s: 'الأسعار', pct: 28 },
      { s: 'CTA النهائي', pct: 5 },
    ],
    daily30: [42,55,38,61,70,58,65,72,48,50,67,80,75,62,55,69,71,83,90,78,65,70,88,95,82,74,68,79,85,91],
  },
  force: {
    name: 'LP Force de Vente',
    visitors: 876, mobile: 74, desktop: 26,
    avgTime: '2:58', avgTimeSec: 178, clicks: 143,
    exits: [
      { s: 'Hero / رأس الصفحة', pct: 30 },
      { s: 'المشكلة والحل', pct: 20 },
      { s: 'المميزات', pct: 14 },
      { s: 'من أنا؟', pct: 10 },
      { s: 'الأسعار', pct: 20 },
      { s: 'CTA النهائي', pct: 6 },
    ],
    daily30: [30,38,25,44,52,40,48,55,33,36,50,60,57,46,40,52,54,64,70,60,48,53,66,72,63,57,51,60,65,70],
  }
};

let extraPages = {};
let currentPageId = 'all';
let visitorsChartInst = null, deviceChartInst = null, convChartInst = null;

// ─── HELPERS ─────────────────────────────────────────
function allData() {
  const all = [...Object.values(PAGES), ...Object.values(extraPages)];
  const v = all.reduce((s,p)=>s+p.visitors,0);
  const cl = all.reduce((s,p)=>s+p.clicks,0);
  const mob = Math.round(all.reduce((s,p)=>s+p.mobile,0)/all.length);
  const sec = Math.round(all.reduce((s,p)=>s+p.avgTimeSec,0)/all.length);
  const m=Math.floor(sec/60),s2=sec%60;
  const daily = PAGES.vente.daily30.map((v2,i)=>{
    let t=v2+(PAGES.force.daily30[i]||0);
    Object.values(extraPages).forEach(p=>{ t+=(p.daily30[i]||0); });
    return t;
  });
  return {
    visitors:v, mobile:mob, desktop:100-mob,
    avgTime:m+':'+(s2<10?'0':'')+s2, avgTimeSec:sec,
    clicks:cl, daily30:daily,
    exits:[
      {s:'Hero / رأس الصفحة',pct:26},{s:'المحتوى الأول',pct:19},
      {s:'المميزات',pct:14},{s:'الشهادات / من أنا',pct:11},
      {s:'الأسعار',pct:24},{s:'CTA النهائي',pct:6},
    ]
  };
}

function getData(id) {
  if(id==='all') return allData();
  return PAGES[id] || extraPages[id];
}

function convRate(d) { return ((d.clicks/d.visitors)*100).toFixed(1); }
function convClass(r) {
  const v=parseFloat(r);
  if(v>15) return 'pill-green';
  if(v>8) return 'pill-orange';
  return 'pill-red';
}

function exitColor(pct) {
  if(pct>=25) return '#E24B4A';
  if(pct>=15) return '#EF9F27';
  return '#91be3f';
}

function periodDays() { return parseInt(document.getElementById('period-sel').value); }

function sliceDays(daily) {
  const d=periodDays();
  return d===30?daily:daily.slice(-d);
}

// ─── RENDER ──────────────────────────────────────────
function renderMetrics(data) {
  const rate = convRate(data);
  const rateCol = parseFloat(rate)>15?'#5f8a1a':parseFloat(rate)>8?'#a0620a':'#a32d2d';
  const cards = [
    { label:'إجمالي الزوار', val:data.visitors.toLocaleString(), delta:'↑ 12%', up:true, icon:usersSVG(), cls:'c-navy', ico:'navy' },
    { label:'من الهاتف', val:data.mobile+'%', delta:Math.round(data.visitors*data.mobile/100).toLocaleString()+' زيارة', up:null, icon:mobileSVG(), cls:'c-blue', ico:'blue' },
    { label:'من الحاسوب', val:data.desktop+'%', delta:Math.round(data.visitors*data.desktop/100).toLocaleString()+' زيارة', up:null, icon:desktopSVG(), cls:'c-blue', ico:'blue' },
    { label:'متوسط وقت البقاء', val:data.avgTime, delta:'↑ 0:18 vs السابق', up:true, icon:clockSVG(), cls:'c-green', ico:'green' },
    { label:'ضغطات التسجيل', val:data.clicks.toLocaleString(), delta:'↑ 8% vs السابق', up:true, icon:clickSVG(), cls:'c-green', ico:'green' },
    { label:'معدل التحويل', val:`<span style="color:${rateCol}">${rate}%</span>`, delta:'من '+data.visitors.toLocaleString()+' زيارة', up:null, icon:convSVG(), cls:'c-navy', ico:'navy' },
  ];
  document.getElementById('metrics-grid').innerHTML = cards.map((c,i)=>`
    <div class="metric-card ${c.cls}" style="animation-delay:${i*0.06}s">
      <div class="metric-icon ${c.ico}">${c.icon}</div>
      <div class="metric-label">${c.label}</div>
      <div class="metric-val">${c.val}</div>
      <div class="metric-delta ${c.up===true?'up':c.up===false?'down':''}">${c.delta}</div>
    </div>
  `).join('');
}

function renderVisitorsChart(data) {
  if(visitorsChartInst) visitorsChartInst.destroy();
  const days = sliceDays(data.daily30);
  const labels = Array.from({length:days.length},(_,i)=>{
    const d=new Date(); d.setDate(d.getDate()-days.length+1+i);
    return (d.getMonth()+1)+'/'+(d.getDate());
  });
  visitorsChartInst = new Chart(document.getElementById('visitorsChart'),{
    type:'line',
    data:{
      labels,
      datasets:[{
        label:'زوار',data:days,
        borderColor:'#1b75bc',
        backgroundColor:'rgba(27,117,188,0.08)',
        fill:true,tension:0.4,pointRadius:2,borderWidth:2,
        pointBackgroundColor:'#1b75bc',
      }]
    },
    options:{
      responsive:true,maintainAspectRatio:false,
      plugins:{legend:{display:false}},
      scales:{
        x:{ticks:{maxTicksLimit:8,font:{size:11,family:'Cairo'}},grid:{display:false}},
        y:{ticks:{font:{size:11,family:'Cairo'}},grid:{color:'rgba(0,0,0,0.05)'}}
      }
    }
  });
}

function renderDeviceChart(data) {
  if(deviceChartInst) deviceChartInst.destroy();
  deviceChartInst = new Chart(document.getElementById('deviceChart'),{
    type:'doughnut',
    data:{
      labels:['الهاتف','الحاسوب'],
      datasets:[{
        data:[data.mobile,data.desktop],
        backgroundColor:['#1b75bc','#91be3f'],
        borderWidth:0,
      }]
    },
    options:{
      responsive:true,maintainAspectRatio:false,
      plugins:{legend:{display:false},tooltip:{callbacks:{label:c=>c.label+': '+c.parsed+'%'}}},
      cutout:'68%',
    }
  });
  document.getElementById('device-list').innerHTML = `
    <div class="device-row-item">
      <div class="device-name"><span class="device-badge" style="background:#1b75bc;"></span>الهاتف</div>
      <div style="font-family:'Outfit',sans-serif;font-weight:700;color:#1b75bc;">${data.mobile}% <span style="font-size:12px;color:#6b7280;font-weight:400;">(${Math.round(data.visitors*data.mobile/100).toLocaleString()})</span></div>
    </div>
    <div class="device-row-item">
      <div class="device-name"><span class="device-badge" style="background:#91be3f;"></span>الحاسوب</div>
      <div style="font-family:'Outfit',sans-serif;font-weight:700;color:#7aa533;">${data.desktop}% <span style="font-size:12px;color:#6b7280;font-weight:400;">(${Math.round(data.visitors*data.desktop/100).toLocaleString()})</span></div>
    </div>
  `;
}

function renderExits(data) {
  document.getElementById('exit-sections').innerHTML = data.exits.map(e=>`
    <div class="exit-row">
      <div class="exit-name">${e.s}</div>
      <div class="exit-bar-bg"><div class="exit-bar-fill" style="width:${e.pct}%;background:${exitColor(e.pct)};"></div></div>
      <div class="exit-pct">${e.pct}%</div>
    </div>
  `).join('');
}

function renderConvChart() {
  if(convChartInst) convChartInst.destroy();
  const allP = [
    {name:'LP Mgmt vente', rate:parseFloat(convRate(PAGES.vente))},
    {name:'LP Force vente', rate:parseFloat(convRate(PAGES.force))},
    ...Object.values(extraPages).map(p=>({name:p.name.substring(0,14)+'…',rate:parseFloat(convRate(p))}))
  ];
  const bgColors = allP.map(p=>p.rate>15?'rgba(145,190,63,0.8)':p.rate>8?'rgba(240,159,39,0.8)':'rgba(217,83,79,0.7)');
  convChartInst = new Chart(document.getElementById('convChart'),{
    type:'bar',
    data:{
      labels:allP.map(p=>p.name),
      datasets:[{
        label:'معدل التحويل %',
        data:allP.map(p=>p.rate),
        backgroundColor:bgColors,
        borderRadius:6,borderWidth:0,
      }]
    },
    options:{
      responsive:true,maintainAspectRatio:false,
      plugins:{legend:{display:false}},
      scales:{
        x:{ticks:{font:{size:11,family:'Cairo'},autoSkip:false,maxRotation:0},grid:{display:false}},
        y:{ticks:{callback:v=>v+'%',font:{size:11}},grid:{color:'rgba(0,0,0,0.05)'}}
      }
    }
  });
}

function renderTable() {
  const rows = [
    PAGES.vente, PAGES.force,
    ...Object.values(extraPages)
  ];
  document.getElementById('pages-tbody').innerHTML = rows.map(r=>{
    const rate = convRate(r);
    return `<tr>
      <td class="td-page">${r.name.length>22?r.name.substring(0,22)+'…':r.name}</td>
      <td style="font-family:'Outfit',sans-serif;font-weight:600;">${r.visitors.toLocaleString()}</td>
      <td>${r.avgTime}</td>
      <td><span class="conv-pill ${convClass(rate)}">${rate}%</span></td>
    </tr>`;
  }).join('');
}

function renderAll(id) {
  const d = getData(id);
  renderMetrics(d);
  renderVisitorsChart(d);
  renderDeviceChart(d);
  renderExits(d);
  renderConvChart();
  renderTable();
  const n = id==='all'?'جميع الصفحات':(PAGES[id]||extraPages[id]||{}).name;
  document.getElementById('page-heading').textContent = 'نظرة عامة — '+n;
}

// ─── EVENTS ──────────────────────────────────────────
function switchPage(id, el) {
  currentPageId = id;
  document.querySelectorAll('.ptab').forEach(t=>t.classList.remove('active'));
  el.classList.add('active');
  renderAll(id);
}

function setNav(el) {
  document.querySelectorAll('.nav-item').forEach(n=>n.classList.remove('active'));
  el.classList.add('active');
}

function onPeriodChange() {
  renderAll(currentPageId);
}

function openModal() {
  document.getElementById('modal-overlay').classList.add('open');
  document.getElementById('code-section').style.display='none';
  document.getElementById('inp-name').value='';
  document.getElementById('inp-id').value='';
  document.getElementById('btn-confirm-add').disabled=true;
  document.getElementById('btn-confirm-add').style.opacity='0.5';
}

function closeModal() {
  document.getElementById('modal-overlay').classList.remove('open');
}

function buildRawCode(name, id) {
  return `<!-- Beecoss Analytics Tracker — ${name} -->
<script>
(function(){
  const PAGE_ID = "${id}";
  const API = "https://your-api.com/track";
  const data = {
    pageId: PAGE_ID,
    device: /Mobi|Android/i.test(navigator.userAgent) ? "mobile" : "desktop",
    start: Date.now(), section: null, converted: false,
  };
  document.querySelectorAll("section[id]").forEach(s=>{
    new IntersectionObserver(e=>{ if(e[0].isIntersecting) data.section=e[0].target.id; },{threshold:0.4}).observe(s);
  });
  document.querySelectorAll(".cta-btn,[data-track='register']").forEach(b=>{
    b.addEventListener("click",()=>{ data.converted=true; send("click"); });
  });
  function send(type){
    navigator.sendBeacon(API, JSON.stringify({...data, type, time: Math.round((Date.now()-data.start)/1000)}));
  }
  window.addEventListener("pagehide", ()=>send("exit"));
})();
<\/script>`;
}

function buildHighlightedCode(name, id) {
  return `<span class="cmt">&lt;!-- Beecoss Analytics Tracker — ${name} --&gt;</span>
<span class="kw">&lt;script&gt;</span>
(function(){
  <span class="kw">const</span> PAGE_ID = <span class="str">"${id}"</span>;
  <span class="kw">const</span> API = <span class="str">"https://your-api.com/track"</span>;
  <span class="kw">const</span> data = {
    pageId: PAGE_ID,
    device: /Mobi|Android/i.test(navigator.userAgent) ? <span class="str">"mobile"</span> : <span class="str">"desktop"</span>,
    start: Date.now(), section: <span class="kw">null</span>, converted: <span class="kw">false</span>,
  };
  document.querySelectorAll(<span class="str">"section[id]"</span>).forEach(s=>{
    <span class="kw">new</span> IntersectionObserver(e=>{ <span class="kw">if</span>(e[0].isIntersecting) data.section=e[0].target.id; },{threshold:0.4}).observe(s);
  });
  document.querySelectorAll(<span class="str">".cta-btn,[data-track='register']"</span>).forEach(b=>{
    b.addEventListener(<span class="str">"click"</span>,()=>{ data.converted=<span class="kw">true</span>; send(<span class="str">"click"</span>); });
  });
  <span class="kw">function</span> send(type){
    navigator.sendBeacon(API, JSON.stringify({...data, type, time: Math.round((Date.now()-data.start)/1000)}));
  }
  window.addEventListener(<span class="str">"pagehide"</span>, ()=>send(<span class="str">"exit"</span>));
})();
<span class="kw">&lt;/script&gt;</span>`;
}

let _deleteTargetId = null;

function askDelete(id) {
  const p = PAGES[id] || extraPages[id];
  if(!p) return;
  _deleteTargetId = id;
  document.getElementById('del-page-name').textContent = p.name;
  document.getElementById('del-modal-overlay').classList.add('open');
}

function closeDelModal() {
  document.getElementById('del-modal-overlay').classList.remove('open');
  _deleteTargetId = null;
}

function confirmDelete() {
  const id = _deleteTargetId;
  if(!id) return;
  const name = (PAGES[id] || extraPages[id] || {}).name || id;

  // remove from data
  delete PAGES[id];
  delete extraPages[id];

  // remove tab element
  const tab = document.querySelector(`.ptab[data-id="${id}"]`);
  if(tab) {
    const wrap = tab.closest('.ptab-wrap');
    if(wrap) wrap.remove(); else tab.remove();
  }

  // if currently viewing deleted page → go back to all
  if(currentPageId === id) {
    currentPageId = 'all';
    document.querySelectorAll('.ptab').forEach(t=>t.classList.remove('active'));
    document.querySelector('.ptab-all').classList.add('active');
    renderAll('all');
  } else {
    renderConvChart(); renderTable();
  }

  closeDelModal();
  showToast('🗑️ تم حذف "'+name+'" نهائياً');
}

function livePreview() {
  const name = document.getElementById('inp-name').value.trim();
  const id = document.getElementById('inp-id').value.trim().replace(/\s+/g,'_').toLowerCase();
  const confirmBtn = document.getElementById('btn-confirm-add');
  const codeSection = document.getElementById('code-section');

  if(name && id) {
    _rawCode = buildRawCode(name, id);
    document.getElementById('code-output').innerHTML = buildHighlightedCode(name, id);
    codeSection.style.display = 'block';
    confirmBtn.disabled = false;
    confirmBtn.style.opacity = '1';
    // reset copy btn
    const cb = document.getElementById('btn-copy');
    cb.classList.remove('copied');
    cb.innerHTML = `<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg> نسخ الكود`;
  } else {
    codeSection.style.display = 'none';
    confirmBtn.disabled = true;
    confirmBtn.style.opacity = '0.5';
  }
}

function copyCode() {
  if(!_rawCode) return;
  navigator.clipboard.writeText(_rawCode).then(()=>{
    const cb = document.getElementById('btn-copy');
    cb.classList.add('copied');
    cb.innerHTML = `<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg> تم النسخ!`;
    setTimeout(()=>{
      cb.classList.remove('copied');
      cb.innerHTML = `<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg> نسخ الكود`;
    }, 2500);
  });
}

function confirmAdd() {
  const name = document.getElementById('inp-name').value.trim();
  const id = document.getElementById('inp-id').value.trim().replace(/\s+/g,'_').toLowerCase();
  if(!name||!id) return;

  extraPages[id] = {
    name, visitors:0, mobile:65, desktop:35,
    avgTime:'0:00', avgTimeSec:0, clicks:0,
    daily30:Array(30).fill(0),
    exits:[
      {s:'Hero / رأس الصفحة',pct:0},{s:'المحتوى',pct:0},
      {s:'المميزات',pct:0},{s:'الأسعار',pct:0},{s:'CTA',pct:0},
    ]
  };

  const tabs = document.getElementById('page-tabs');
  const wrap = document.createElement('div');
  wrap.className = 'ptab-wrap';
  const btn = document.createElement('button');
  btn.className='ptab'; btn.dataset.id=id;
  btn.textContent=name;
  btn.onclick=()=>switchPage(id,btn);
  const delBtn = document.createElement('button');
  delBtn.className='ptab-delete'; delBtn.title='حذف الصفحة';
  delBtn.innerHTML=`<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14H6L5 6"/><path d="M10 11v6M14 11v6"/><path d="M9 6V4h6v2"/></svg>`;
  delBtn.onclick=()=>askDelete(id);
  wrap.appendChild(btn); wrap.appendChild(delBtn);
  tabs.appendChild(wrap);

  renderConvChart(); renderTable();
  closeModal();
  showToast('✅ تمت إضافة "'+name+'" — لا تنسَ لصق الكود في صفحتك!');
}

function showToast(msg) {
  const t=document.getElementById('toast');
  document.getElementById('toast-msg').textContent=msg;
  t.classList.add('show');
  setTimeout(()=>t.classList.remove('show'),3000);
}

