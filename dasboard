<!-- ── Main ── -->
<main class="main">
  <div class="topbar">
    <div class="topbar-left">
      <h1 id="page-heading">نظرة عامة — جميع الصفحات</h1>
      <p id="page-sub">آخر 30 يوم • يتم التحديث تلقائياً</p>
