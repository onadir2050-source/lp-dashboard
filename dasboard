<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Beecoss — Analytics Dashboard</title>
<link href="https://fonts.googleapis.com/css2?family=Cairo:wght@300;400;500;600;700;800&family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.js"></script>
<style>
:root {
  --navy: #253B74;
  --navy-dark: #1a2a56;
  --navy-light: #2f4a90;
  --green: #91be3f;
  --green-dark: #7aa533;
  --green-light: #a8d44e;
  --blue: #1b75bc;
  --blue-light: #2889d4;
  --bg: #f4f6fb;
  --sidebar-w: 260px;
  --card-radius: 14px;
  --white: #ffffff;
  --text: #1a1a2e;
  --text-muted: #6b7280;
  --border: rgba(37,59,116,0.1);
}

* { margin: 0; padding: 0; box-sizing: border-box; }

body {
  font-family: 'Cairo', sans-serif;
  background: var(--bg);
  color: var(--text);
  min-height: 100vh;
  display: flex;
}

/* ── Sidebar ── */
.sidebar {
  width: var(--sidebar-w);
  background: var(--navy);
  min-height: 100vh;
  position: fixed;
  top: 0; right: 0;
  display: flex;
  flex-direction: column;
  z-index: 100;
  box-shadow: -4px 0 24px rgba(37,59,116,0.2);
}

.sidebar-logo {
  padding: 28px 24px 20px;
  border-bottom: 1px solid rgba(255,255,255,0.1);
  display: flex;
  align-items: center;
  gap: 12px;
}

/* Beecoss SVG Logo */
.logo-mark {
  width: 42px;
  height: 42px;
  flex-shrink: 0;
}

.logo-text {
  font-family: 'Outfit', sans-serif;
  font-weight: 700;
  font-size: 20px;
  color: #fff;
  letter-spacing: -0.3px;
}
.logo-text span { color: var(--green); }

.sidebar-label {
  padding: 20px 24px 8px;
  font-size: 10px;
  font-weight: 600;
  letter-spacing: 1.5px;
  color: rgba(255,255,255,0.35);
  text-transform: uppercase;
}

.nav-item {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 11px 24px;
  color: rgba(255,255,255,0.6);
  cursor: pointer;
  border-right: 3px solid transparent;
  transition: all 0.2s;
  font-size: 14px;
  font-weight: 500;
}
.nav-item:hover { color: #fff; background: rgba(255,255,255,0.06); }
.nav-item.active {
  color: #fff;
  background: rgba(145,190,63,0.15);
  border-right-color: var(--green);
}
.nav-item svg { width: 18px; height: 18px; flex-shrink: 0; opacity: 0.8; }
.nav-item.active svg { opacity: 1; }

.sidebar-footer {
  margin-top: auto;
  padding: 20px 24px;
  border-top: 1px solid rgba(255,255,255,0.1);
  font-size: 12px;
  color: rgba(255,255,255,0.35);
  text-align: center;
}

/* ── Main ── */
.main {
  margin-right: var(--sidebar-w);
  flex: 1;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}

.topbar {
  background: var(--white);
  border-bottom: 1px solid var(--border);
  padding: 0 32px;
  height: 68px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  position: sticky;
  top: 0;
  z-index: 50;
}

.topbar-left h1 {
  font-size: 17px;
  font-weight: 700;
  color: var(--navy);
}
.topbar-left p {
  font-size: 12px;
  color: var(--text-muted);
  margin-top: 1px;
}

.topbar-right {
  display: flex;
  align-items: center;
  gap: 12px;
}

.period-select {
  border: 1.5px solid var(--border);
  border-radius: 8px;
  padding: 7px 14px;
  font-size: 13px;
  font-family: 'Cairo', sans-serif;
  color: var(--navy);
  background: var(--white);
  cursor: pointer;
  outline: none;
}

.btn-add {
  background: var(--green);
  color: #fff;
  border: none;
  padding: 8px 18px;
  border-radius: 8px;
  font-size: 13px;
  font-family: 'Cairo', sans-serif;
  font-weight: 600;
  cursor: pointer;
  display: flex;
  align-items: center;
  gap: 6px;
  transition: background 0.2s;
}
.btn-add:hover { background: var(--green-dark); }

.content { padding: 28px 32px; flex: 1; }

/* ── Page Tabs ── */
.page-tabs {
  display: flex;
  gap: 8px;
  margin-bottom: 24px;
  flex-wrap: wrap;
}

.ptab {
  padding: 8px 16px;
  border-radius: 8px;
  border: 1.5px solid var(--border);
  background: var(--white);
  font-size: 13px;
  font-family: 'Cairo', sans-serif;
  font-weight: 500;
  color: var(--text-muted);
  cursor: pointer;
  transition: all 0.2s;
}
.ptab:hover { border-color: var(--blue); color: var(--blue); }
.ptab.active {
  background: var(--navy);
  border-color: var(--navy);
  color: #fff;
  font-weight: 600;
}
.ptab-all.active { background: var(--blue); border-color: var(--blue); }

.ptab-wrap { position: relative; display: inline-flex; align-items: center; }
.ptab-wrap .ptab { padding-left: 34px; }
.ptab-delete {
  position: absolute; left: 8px;
  width: 18px; height: 18px; border-radius: 4px;
  border: none; background: transparent; color: var(--text-muted);
  cursor: pointer; display: flex; align-items: center; justify-content: center;
  opacity: 0; transition: all 0.15s; padding: 0;
}
.ptab-wrap:hover .ptab-delete { opacity: 1; }
.ptab-delete:hover { background: rgba(217,83,79,0.12); color: #d9534f; }
.ptab-delete svg { width: 12px; height: 12px; pointer-events: none; }

.demo-badge {
  display: inline-flex; align-items: center; gap: 6px;
  background: rgba(240,159,39,0.12); border: 1px solid rgba(240,159,39,0.35);
  color: #a0620a; font-size: 11px; font-weight: 600;
  padding: 4px 10px; border-radius: 6px; margin-bottom: 16px;
}

.del-modal-overlay {
  display: none; position: fixed; inset: 0;
  background: rgba(10,20,50,0.6); z-index: 300;
  align-items: center; justify-content: center;
}
.del-modal-overlay.open { display: flex; }
.del-modal {
  background: var(--white); border-radius: 16px; padding: 28px 32px;
  width: 400px; max-width: 95vw;
  box-shadow: 0 20px 60px rgba(37,59,116,0.25);
  animation: modalIn 0.2s ease; text-align: center;
}
.del-icon {
  width: 52px; height: 52px; border-radius: 50%;
  background: rgba(217,83,79,0.1);
  display: flex; align-items: center; justify-content: center;
  margin: 0 auto 16px;
}
.del-icon svg { width: 24px; height: 24px; color: #d9534f; }
.del-modal h3 { font-size: 16px; font-weight: 700; color: var(--navy); margin-bottom: 8px; }
.del-modal p { font-size: 13px; color: var(--text-muted); line-height: 1.6; margin-bottom: 6px; }
.del-warning {
  background: rgba(217,83,79,0.07); border: 1px solid rgba(217,83,79,0.2);
  border-radius: 8px; padding: 9px 14px;
  font-size: 12px; color: #a32d2d; font-weight: 600; margin: 12px 0 20px;
}
.del-actions { display: flex; gap: 10px; justify-content: center; }
.btn-delete-confirm {
  padding: 9px 22px; border-radius: 8px; border: none;
  background: #d9534f; color: #fff;
  font-family: 'Cairo', sans-serif; font-size: 13px; font-weight: 700;
  cursor: pointer; transition: background 0.2s;
}
.btn-delete-confirm:hover { background: #c0392b; }

/* ── Metrics Grid ── */
.metrics-grid {
  display: grid;
  grid-template-columns: repeat(6, 1fr);
  gap: 14px;
  margin-bottom: 22px;
}

.metric-card {
  background: var(--white);
  border-radius: var(--card-radius);
  padding: 18px 18px 16px;
  border: 1px solid var(--border);
  position: relative;
  overflow: hidden;
  animation: fadeUp 0.4s ease both;
}
.metric-card::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 3px;
}
.metric-card.c-navy::before { background: var(--navy); }
.metric-card.c-green::before { background: var(--green); }
.metric-card.c-blue::before { background: var(--blue); }

.metric-icon {
  width: 36px;
  height: 36px;
  border-radius: 9px;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 10px;
}
.metric-icon.navy { background: rgba(37,59,116,0.1); }
.metric-icon.green { background: rgba(145,190,63,0.12); }
.metric-icon.blue { background: rgba(27,117,188,0.1); }
.metric-icon svg { width: 18px; height: 18px; }
.metric-icon.navy svg { color: var(--navy); }
.metric-icon.green svg { color: var(--green-dark); }
.metric-icon.blue svg { color: var(--blue); }

.metric-label { font-size: 11px; font-weight: 600; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.6px; margin-bottom: 4px; }
.metric-val { font-size: 24px; font-weight: 800; color: var(--navy); font-family: 'Outfit', sans-serif; }
.metric-delta { font-size: 11px; margin-top: 4px; font-weight: 600; }
.up { color: #3a9c6e; }
.down { color: #d9534f; }

/* ── Charts Row ── */
.charts-row {
  display: grid;
  grid-template-columns: 2fr 1fr;
  gap: 16px;
  margin-bottom: 20px;
}

.card {
  background: var(--white);
  border-radius: var(--card-radius);
  padding: 22px 24px;
  border: 1px solid var(--border);
  animation: fadeUp 0.5s ease both;
}

.card-title {
  font-size: 13px;
  font-weight: 700;
  color: var(--navy);
  margin-bottom: 4px;
  display: flex;
  align-items: center;
  gap: 8px;
}
.card-title-dot {
  width: 8px; height: 8px; border-radius: 50%;
  display: inline-block;
}
.card-sub { font-size: 12px; color: var(--text-muted); margin-bottom: 18px; }

/* ── Device donut ── */
.device-list { margin-top: 14px; }
.device-row-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 8px 0;
  border-bottom: 1px solid var(--border);
  font-size: 13px;
}
.device-row-item:last-child { border-bottom: none; }
.device-name { display: flex; align-items: center; gap: 8px; font-weight: 500; color: var(--navy); }
.device-badge {
  display: inline-block;
  width: 10px; height: 10px; border-radius: 3px;
}

/* ── Exit Sections ── */
.exit-row {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-bottom: 10px;
  font-size: 13px;
}
.exit-name { width: 170px; flex-shrink: 0; color: var(--text); font-weight: 500; }
.exit-bar-bg { flex: 1; height: 8px; background: var(--bg); border-radius: 4px; overflow: hidden; }
.exit-bar-fill { height: 100%; border-radius: 4px; transition: width 0.6s ease; }
.exit-pct { width: 38px; text-align: left; color: var(--text-muted); font-weight: 600; font-family: 'Outfit', sans-serif; font-size: 12px; }

/* ── All Pages Table ── */
.table-wrap { overflow-x: auto; }
table { width: 100%; border-collapse: collapse; font-size: 13px; }
thead th {
  text-align: right;
  padding: 10px 14px;
  color: var(--text-muted);
  font-weight: 600;
  font-size: 11px;
  text-transform: uppercase;
  letter-spacing: 0.5px;
  border-bottom: 1.5px solid var(--border);
  background: var(--bg);
}
tbody td {
  padding: 13px 14px;
  border-bottom: 1px solid var(--border);
  color: var(--text);
}
tbody tr:last-child td { border-bottom: none; }
tbody tr:hover { background: rgba(37,59,116,0.03); }
.td-page { font-weight: 600; color: var(--navy); }
.conv-pill {
  display: inline-block;
  padding: 3px 10px;
  border-radius: 20px;
  font-weight: 700;
  font-size: 11px;
  font-family: 'Outfit', sans-serif;
}
.pill-green { background: rgba(145,190,63,0.15); color: #5f8a1a; }
.pill-orange { background: rgba(240,159,39,0.15); color: #a0620a; }
.pill-red { background: rgba(226,75,74,0.1); color: #a32d2d; }

/* ── Bottom Row ── */
.bottom-row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-top: 20px; }

/* ── Modal ── */
.modal-overlay {
  display: none;
  position: fixed; inset: 0;
  background: rgba(10,20,50,0.55);
  z-index: 200;
  align-items: center;
  justify-content: center;
}
.modal-overlay.open { display: flex; }
.modal {
  background: var(--white);
  border-radius: 16px;
  padding: 32px;
  width: 460px;
  max-width: 95vw;
  box-shadow: 0 20px 60px rgba(37,59,116,0.2);
  animation: modalIn 0.25s ease;
}
@keyframes modalIn { from { transform: scale(0.94); opacity: 0; } to { transform: scale(1); opacity: 1; } }
.modal h3 { font-size: 16px; font-weight: 700; color: var(--navy); margin-bottom: 6px; }
.modal p { font-size: 13px; color: var(--text-muted); margin-bottom: 20px; }
.form-group { margin-bottom: 14px; }
.form-group label { display: block; font-size: 12px; font-weight: 600; color: var(--navy); margin-bottom: 5px; }
.form-group input {
  width: 100%;
  padding: 10px 14px;
  border: 1.5px solid var(--border);
  border-radius: 9px;
  font-family: 'Cairo', sans-serif;
  font-size: 13px;
  color: var(--text);
  outline: none;
  transition: border 0.2s;
}
.form-group input:focus { border-color: var(--blue); }
.modal-hint {
  background: rgba(145,190,63,0.1);
  border-right: 3px solid var(--green);
  padding: 10px 14px;
  border-radius: 8px;
  font-size: 12px;
  color: #4a7010;
  margin-bottom: 20px;
}
.modal-actions { display: flex; gap: 10px; justify-content: flex-end; }
.btn-ghost {
  padding: 9px 20px;
  border-radius: 8px;
  border: 1.5px solid var(--border);
  background: transparent;
  font-family: 'Cairo', sans-serif;
  font-size: 13px;
  font-weight: 600;
  color: var(--text-muted);
  cursor: pointer;
}
.btn-confirm {
  padding: 9px 20px;
  border-radius: 8px;
  border: none;
  background: var(--navy);
  color: #fff;
  font-family: 'Cairo', sans-serif;
  font-size: 13px;
  font-weight: 700;
  cursor: pointer;
  transition: background 0.2s;
}
.btn-confirm:hover { background: var(--navy-dark); }

/* ── Code Snippet ── */
.code-section {
  margin-top: 16px;
  border-top: 1px solid var(--border);
  padding-top: 14px;
}
.code-section-label {
  font-size: 11px;
  font-weight: 700;
  color: var(--text-muted);
  text-transform: uppercase;
  letter-spacing: 0.8px;
  margin-bottom: 8px;
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.btn-copy {
  display: flex;
  align-items: center;
  gap: 5px;
  padding: 4px 12px;
  border-radius: 6px;
  border: 1.5px solid var(--green);
  background: transparent;
  color: var(--green-dark);
  font-family: 'Cairo', sans-serif;
  font-size: 11px;
  font-weight: 700;
  cursor: pointer;
  transition: all 0.2s;
}
.btn-copy:hover { background: rgba(145,190,63,0.1); }
.btn-copy.copied { background: var(--green); color: #fff; border-color: var(--green); }
.code-block {
  background: #0f172a;
  border-radius: 10px;
  padding: 14px 16px;
  font-family: 'Courier New', monospace;
  font-size: 11.5px;
  color: #93c5fd;
  overflow-x: auto;
  line-height: 1.7;
  max-height: 220px;
  overflow-y: auto;
}
.code-block .cmt { color: #4ade80; }
.code-block .str { color: #fbbf24; }
.code-block .kw { color: #c084fc; }

/* ── Toast ── */
.toast {
  position: fixed;
  bottom: 24px;
  left: 50%;
  transform: translateX(-50%) translateY(80px);
  background: var(--navy);
  color: #fff;
  padding: 12px 24px;
  border-radius: 10px;
  font-size: 14px;
  font-weight: 600;
  z-index: 999;
  transition: transform 0.3s ease;
  display: flex;
  align-items: center;
  gap: 10px;
}
.toast.show { transform: translateX(-50%) translateY(0); }
.toast-dot { width: 8px; height: 8px; border-radius: 50%; background: var(--green); }

@keyframes fadeUp {
  from { opacity: 0; transform: translateY(12px); }
  to { opacity: 1; transform: translateY(0); }
}

/* ── Responsive ── */
@media(max-width: 1200px) {
  .metrics-grid { grid-template-columns: repeat(3, 1fr); }
}
@media(max-width: 960px) {
  :root { --sidebar-w: 0px; }
  .sidebar { display: none; }
  .charts-row, .bottom-row { grid-template-columns: 1fr; }
  .content { padding: 20px 16px; }
  .topbar { padding: 0 16px; }
}
@media(max-width: 680px) {
  .metrics-grid { grid-template-columns: repeat(2, 1fr); }
}
</style>
</head>
<body>

<!-- ── Sidebar ── -->
<aside class="sidebar">
  <div class="sidebar-logo">
